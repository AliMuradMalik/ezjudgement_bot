OPENAI_API_KEY=sk-...
DATABASE_URL=postgresql://user:password@host:25060/dbname?sslmode=require

CORS_ORIGINS=["https://your-frontend.example.com"]
ENVIRONMENT=production
LOG_LEVEL=INFO

VECTOR_STORE_ID=vs_...
MODEL=gpt-4.1
MAX_NUM_RESULTS=10

# Folder of original PDFs backing the vector store, laid out as
#   <SERIES>/<YEAR>/{judgment,headnote}/<NAME>.pdf
# Single-quoted because the folder name contains a backslash, a colon and
# spaces. The path is relative to the project root, so it points at the sibling
# scrapper_final folder regardless of the server user (an absolute path works too).
SOURCES_DIR='../scrapper_final/D:\judgment and headnote scrapper'

DB_POOL_MIN=1
DB_POOL_MAX=10
